# 必須: Renderのダッシュボード > Environment Variables で設定すること
# このファイルをコピーして .env を作成し、値を埋める（.env はGitにコミットしないこと）

DATABASE_URL=postgresql://...        # Neon接続文字列
ADMIN_PASSWORD=                      # 管理者パスワード（空のままデプロイ禁止）
RESIDENT_PASSWORD=                   # 住民パスワード（空のままデプロイ禁止）
BOARD_PASSWORD=                      # 理事会パスワード（空のままデプロイ禁止）
RESEND_API_KEY=                      # メール送信用（任意）
APP_BASE_URL=https://proud-library.onrender.com
